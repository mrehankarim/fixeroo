# Environment Variables Template

# Copy this file to .env and fill in your values
# Do not commit .env file to version control

# ==========================================
# Firebase Configuration
# ==========================================

# Get these from Firebase Console > Project Settings
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
REACT_APP_FIREBASE_PROJECT_ID=your_project_id_here
REACT_APP_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
REACT_APP_FIREBASE_APP_ID=your_app_id_here
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ==========================================
# Email Configuration (for OTP sending)
# ==========================================

# Option 1: Firebase Cloud Functions
REACT_APP_OTP_FUNCTION_URL=https://your-region-your-project.cloudfunctions.net/sendOTP

# Option 2: SendGrid
REACT_APP_SENDGRID_API_KEY=your_sendgrid_api_key_here
REACT_APP_SENDGRID_FROM_EMAIL=noreply@example.com

# Option 3: Mailgun
REACT_APP_MAILGUN_API_KEY=your_mailgun_api_key_here
REACT_APP_MAILGUN_DOMAIN=your_mailgun_domain_here

# ==========================================
# Backend API Configuration
# ==========================================

REACT_APP_API_URL=https://api.example.com
REACT_APP_API_TIMEOUT=30000

# ==========================================
# App Configuration
# ==========================================

# Environment
REACT_APP_ENV=development
# development | staging | production

# Debug Mode
REACT_APP_DEBUG=true

# Feature Flags
REACT_APP_ENABLE_SOCIAL_LOGIN=true
REACT_APP_ENABLE_PHONE_VERIFICATION=false
REACT_APP_ENABLE_TWO_FACTOR_AUTH=false

# ==========================================
# Analytics Configuration (Optional)
# ==========================================

REACT_APP_ANALYTICS_ID=your_analytics_id_here
REACT_APP_SENTRY_DSN=your_sentry_dsn_here

# ==========================================
# Miscellaneous
# ==========================================

# App Name
REACT_APP_NAME=My Service App

# Support Email
REACT_APP_SUPPORT_EMAIL=support@example.com

# Privacy Policy URL
REACT_APP_PRIVACY_POLICY_URL=https://example.com/privacy

# Terms of Service URL
REACT_APP_TERMS_OF_SERVICE_URL=https://example.com/terms
